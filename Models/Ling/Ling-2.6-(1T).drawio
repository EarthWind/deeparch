rmal;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(62, 62, 62)); font-weight: normal;&quot;&gt;&lt;div style=&quot;font-weight: 700;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(62, 62, 62)); font-weight: normal;&quot;&gt;Layer 9&amp;nbsp; &amp;nbsp; : Linear attention -&amp;gt; FFN&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;font-weight: 700;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(62, 62, 62)); font-weight: normal;&quot;&gt;Layer 10&amp;nbsp; : Linear attention -&amp;gt; FFN&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;font-weight: 700;&quot;&gt;&lt;div&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(62, 62, 62)); font-weight: normal;&quot;&gt;Layer 11&amp;nbsp; : Linear attention -&amp;gt; FFN&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(62, 62, 62)); font-weight: normal;&quot;&gt;Layer 12&amp;nbsp; : Linear attention -&amp;gt; FFN&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(62, 62, 62)); font-weight: normal;&quot;&gt;Layer 13&amp;nbsp; : Linear attention -&amp;gt; FFN&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(62, 62, 62)); font-weight: normal;&quot;&gt;Layer 14&amp;nbsp; : Linear attention -&amp;gt; FFN&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(62, 62, 62)); font-weight: normal;&quot;&gt;Layer 15&amp;nbsp; : Linear attention -&amp;gt; FFN&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(62, 62, 62)); font-weight: normal; background-color: transparent;&quot;&gt;Layer 16&amp;nbsp; : Fullattention&amp;nbsp; &amp;nbsp; &amp;nbsp; -&amp;gt; FFN&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(62, 62, 62)); fon